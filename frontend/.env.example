# ============================================================
# Frontend Environment Variables - Copy to .env and fill in
# ============================================================

# Full backend API base URL (must end with /api)
# Railway example: https://YOUR-SERVICE-NAME.up.railway.app/api
VITE_API_BASE_URL=https://your-railway-backend.up.railway.app/api

# Razorpay public key (safe to expose in frontend)
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
